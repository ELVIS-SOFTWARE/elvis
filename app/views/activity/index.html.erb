<div class="row wrapper border-bottom white-bg page-heading m-b-md">
    <h2>
        Liste des cours
        <% unless @current_user.is_teacher && !@current_user.is_admin %>
            <%= link_to addCourse_path, class: "btn btn-sm btn-primary pull-right" do %>
                <i class="fas fa-plus"></i> Ajouter un cours
            <% end %>
        <% end %>
    </h2>
</div>

<div class="row">

</div>

<div class="row">
    <div class="col-lg-12">
        <div class="ibox">
            <div class="ibox-content no-padding">
                <%seasons_json = @seasons.as_json( methods: [:is_next])%>
                <%= react_component "courses/LessonList", {
                    activityRefs: @activity_refs,
                    teachers: @teachers,
                    seasons: seasons_json,
                    rooms: @rooms,
                    locations: @locations,
                    evaluationLevelRefs: @evaluation_level_refs,
                    currentUser: @current_user,
                    isTeacherView: @current_user.is_teacher && !@current_user.is_admin
                } %>
            </div>
        </div>
    </div>
</div>
